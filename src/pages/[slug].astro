---
import BaseLayout from "~/layouts/BaseLayout.astro";
import ThemeToggle from "~/components/ThemeToggle.astro";
import { ALL_TOOLS, getToolBySlug } from "~/tools";

export async function getStaticPaths() {
  return ALL_TOOLS.map((tool) => ({
    params: { slug: tool.slug },
  }));
}

const { slug } = Astro.params;
const tool = getToolBySlug(slug!);
if (!tool) return Astro.redirect("/", 301);

const UIComponent = await import(`~/tools/${slug}-ui.astro`);
---

<BaseLayout title={tool.title} description={tool.description}>
  <ThemeToggle />
  <UIComponent.default />

  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    "itemListElement": [
      { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://usequickutils.com/" },
      { "@type": "ListItem", "position": 2, "name": tool.title, "item": `https://usequickutils.com/${tool.slug}/` }
    ]
  })}></script>

  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": tool.faq.map(f => ({
      "@type": "Question",
      "name": f.q,
      "acceptedAnswer": { "@type": "Answer", "text": f.a }
    }))
  })}></script>

  {tool.faq.length > 0 && (
    <div class="max-w-4xl mx-auto mt-16 mb-8">
      <h2 class="text-xl font-bold tracking-[-0.04em] mb-6">Frequently Asked Questions</h2>
      <div class="divide-y divide-border dark:divide-dark-border border-t border-border dark:border-dark-border">
        {tool.faq.map((f) => (
          <details class="group py-4 cursor-pointer">
            <summary class="text-sm font-medium tracking-[-0.04em] list-none flex items-center justify-between">
              {f.q}
              <svg class="w-4 h-4 text-gray-400 group-open:rotate-180 transition-transform" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="6 9 12 15 18 9"/></svg>
            </summary>
            <p class="text-sm text-gray-500 dark:text-gray-400 mt-3 leading-relaxed tracking-[-0.04em]">{f.a}</p>
          </details>
        ))}
      </div>
    </div>
  )}
</BaseLayout>
