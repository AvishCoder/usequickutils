<div class="max-w-4xl mx-auto">
    <h1 class="text-3xl font-bold tracking-[-0.04em] mb-2">Add Password to PDF</h1>
    <p class="text-gray-400 dark:text-gray-500 mb-8 tracking-[-0.04em]">Encrypt a PDF file with a password for protection.</p>
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-8">
      <div class="space-y-6">
        <div id="dropzone" class="border-2 border-dashed border-border dark:border-dark-border rounded-[6px] p-12 text-center cursor-pointer hover:border-black dark:hover:border-white transition-all duration-150">
          <div class="flex flex-col items-center gap-3">
            <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" class="text-gray-400" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="17 8 12 3 7 8"/><line x1="12" y1="3" x2="12" y2="15"/></svg>
            <p class="text-sm text-gray-500 dark:text-gray-400 tracking-[-0.04em]">Drop a PDF here, or <span class="text-black dark:text-white underline">browse</span></p>
            <input id="file-input" type="file" accept=".pdf,application/pdf" class="hidden" />
          </div>
        </div>
        <div class="space-y-4">
          <div><label class="block text-sm font-medium mb-2 tracking-[-0.04em]">Password</label><input id="password-input" type="password" placeholder="Enter password" class="w-full px-4 py-2 rounded-[6px] border border-border dark:border-dark-border bg-white dark:bg-dark-surface text-sm tracking-[-0.04em] focus:outline-none focus:border-black dark:focus:border-white transition-colors" /></div>
          <div><label class="block text-sm font-medium mb-2 tracking-[-0.04em]">Confirm Password</label><input id="confirm-input" type="password" placeholder="Confirm password" class="w-full px-4 py-2 rounded-[6px] border border-border dark:border-dark-border bg-white dark:bg-dark-surface text-sm tracking-[-0.04em] focus:outline-none focus:border-black dark:focus:border-white transition-colors" /></div>
          <p id="error-msg" class="text-xs text-red-500 tracking-[-0.04em] hidden"></p>
        </div>
        <button id="protect-btn" disabled class="w-full py-3 rounded-[6px] bg-black text-white dark:bg-white dark:text-black font-semibold text-sm tracking-[-0.04em] disabled:opacity-30 disabled:cursor-not-allowed hover:opacity-90 transition-opacity">Protect PDF</button>
      </div>
      <div id="file-status" class="hidden border border-border dark:border-dark-border rounded-[6px] p-4 bg-white dark:bg-dark-surface">
        <div class="flex items-center gap-3">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" class="text-green-500 shrink-0" stroke-linecap="round" stroke-linejoin="round"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg>
          <div><p id="file-name" class="text-sm font-medium tracking-[-0.04em]"></p><p class="text-xs text-gray-400 tracking-[-0.04em]">Loaded successfully</p></div>
        </div>
      </div>
      <div id="output-panel" class="hidden space-y-4">
        <div class="grid grid-cols-2 gap-3 text-[11px] font-mono uppercase tracking-[0.05em]">
          <div class="border border-border dark:border-dark-border rounded-[6px] p-3 bg-white dark:bg-dark-surface"><span class="text-gray-400">Original</span><p id="original-size" class="text-base font-semibold mt-1">—</p><p id="original-name" class="text-gray-400 mt-0.5 truncate">—</p></div>
          <div class="border border-border dark:border-dark-border rounded-[6px] p-3 bg-white dark:bg-dark-surface"><span class="text-gray-400">Encrypted</span><p id="encrypted-size" class="text-base font-semibold mt-1">—</p><p id="status-info" class="text-gray-400 mt-0.5">AES-256</p></div>
        </div>
        <button id="download-btn" class="w-full py-3 rounded-full bg-black text-white dark:bg-white dark:text-black font-semibold text-sm tracking-[-0.04em] hover:opacity-90 transition-opacity hidden">Download Encrypted PDF</button>
      </div>
    </div>
  </div>
  <script>
  (function(){
    const dz=document.getElementById("dropzone"),fi=document.getElementById("file-input"),pw=document.getElementById("password-input"),ci=document.getElementById("confirm-input"),em=document.getElementById("error-msg"),pb=document.getElementById("protect-btn"),fs=document.getElementById("file-status"),fn=document.getElementById("file-name"),op=document.getElementById("output-panel"),os=document.getElementById("original-size"),on=document.getElementById("original-name"),es=document.getElementById("encrypted-size"),si=document.getElementById("status-info"),db=document.getElementById("download-btn");
    let f=null,ed=null;
    dz.onclick=()=>fi.click();dz.ondragover=e=>{e.preventDefault();dz.classList.add("border-black","dark:border-white")};dz.ondragleave=()=>{dz.classList.remove("border-black","dark:border-white")};dz.ondrop=e=>{e.preventDefault();dz.classList.remove("border-black","dark:border-white");const file=e.dataTransfer?.files?.[0];if(file&&file.type==="application/pdf")hF(file);else if(file&&file.name.toLowerCase().endsWith(".pdf"))hF(file)};fi.onchange=()=>{if(fi.files?.[0])hF(fi.files[0])};
    function hF(file){f=file;fn.textContent=file.name;fs.classList.remove("hidden");os.textContent=(file.size/1024).toFixed(1)+" KB";on.textContent=file.name;op.classList.remove("hidden");pw.disabled=false;ci.disabled=false;pb.disabled=false;ed=null;db.classList.add("hidden");vI()}
    function vI(){const p=pw.value,c=ci.value;pb.disabled=!(f&&p&&c&&p===c);if(p&&c&&p!==c){em.textContent="Passwords do not match";em.classList.remove("hidden")}else{em.classList.add("hidden")}}
    pw.oninput=vI;ci.oninput=vI;
    pb.onclick=async()=>{if(!f||pw.value!==ci.value||!pw.value)return;pb.disabled=true;pb.textContent="Encrypting...";try{const b=await f.arrayBuffer();const{PDFDocument}=await import("https://esm.sh/pdf-lib-with-encrypt@1.2.1");const d=await PDFDocument.load(b);d.encrypt({userPassword:pw.value,ownerPassword:pw.value});const eb=await d.save();ed=new Blob([eb],{type:"application/pdf"});es.textContent=(ed.size/1024).toFixed(1)+" KB";si.textContent="AES-256";op.classList.remove("hidden");db.classList.remove("hidden");db.onclick=()=>{const a=document.createElement("a");a.href=URL.createObjectURL(ed);a.download="protected-"+f.name;a.click()}}catch(e){em.textContent="Error: "+(e.message||"Failed to encrypt PDF");em.classList.remove("hidden")}pb.disabled=false;pb.textContent="Protect PDF"};
  })();
  </script>
