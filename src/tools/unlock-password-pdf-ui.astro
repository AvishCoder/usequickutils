<div class="max-w-3xl mx-auto">
    <h1 class="text-3xl font-bold tracking-[-0.04em] mb-2">Unlock Password PDF</h1>
    <p class="text-gray-400 dark:text-gray-500 mb-8 tracking-[-0.04em]">Remove password protection from PDF files.</p>
    <div id="dropzone" class="border-2 border-dashed border-border dark:border-dark-border rounded-[6px] p-12 text-center cursor-pointer hover:border-black dark:hover:border-white transition-all duration-150 mb-6"><p class="text-sm text-gray-500 dark:text-gray-400 tracking-[-0.04em]">Drop a PDF here</p><input id="file-input" type="file" accept=".pdf,application/pdf" class="hidden" /></div>
    <div class="mb-4"><label class="block text-sm font-medium mb-2 tracking-[-0.04em]">PDF Password</label><input id="password-input" type="password" placeholder="Enter PDF password" class="w-full px-4 py-2 rounded-[6px] border border-border dark:border-dark-border bg-white dark:bg-dark-surface text-sm tracking-[-0.04em] focus:outline-none focus:border-black dark:focus:border-white" /></div>
    <button id="unlock-btn" disabled class="w-full py-3 rounded-[6px] bg-black text-white dark:bg-white dark:text-black font-semibold text-sm disabled:opacity-30">Unlock PDF</button>
    <p class="text-xs text-gray-400 mt-4 tracking-[-0.04em]">Coming soon: Full PDF.js integration for client-side decryption.</p>
  </div>
  <script>
  (function(){
    const dz=document.getElementById("dropzone"),fi=document.getElementById("file-input"),pw=document.getElementById("password-input"),ub=document.getElementById("unlock-btn");
    dz.onclick=()=>fi.click();dz.ondragover=e=>e.preventDefault();fi.onchange=()=>{ub.disabled=!fi.files?.length||!pw.value};pw.oninput=()=>{ub.disabled=!fi.files?.length||!pw.value};ub.onclick=()=>{alert("PDF unlock will use pdf.js in the next update.")};
  })();
  </script>
