---
import { CATEGORIES, getToolsByCategory } from "~/tools";

const currentPath = Astro.url.pathname.replace(/\/$/, "") || "/";

const CATEGORY_ICONS = {
  Image: `<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="3" width="18" height="18" rx="2" ry="2"/><circle cx="8.5" cy="8.5" r="1.5"/><polyline points="21 15 16 10 5 21"/></svg>`,
  PDF: `<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/><line x1="16" y1="13" x2="8" y2="13"/><line x1="16" y1="17" x2="8" y2="17"/></svg>`,
  Text: `<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="4 7 4 4 20 4 20 7"/><line x1="9" y1="20" x2="15" y2="20"/><line x1="12" y1="4" x2="12" y2="20"/></svg>`,
};
---

<nav class="fixed left-0 top-0 z-40 w-64 h-screen border-r border-border dark:border-dark-border bg-white dark:bg-dark-surface overflow-y-auto overflow-x-hidden">
  <div class="px-6 pt-8 pb-6 border-b border-border dark:border-dark-border">
    <a href="/" class="inline-block text-2xl font-bold tracking-[-0.04em] hover:opacity-60 transition-opacity">quickutils</a>
    <p class="text-xs text-gray-400 dark:text-gray-500 mt-1 tracking-[-0.04em]">browser utilities</p>
  </div>

  <div class="px-3 py-5 space-y-6">
    {CATEGORIES.map((cat) => {
      const tools = getToolsByCategory(cat.key);
      return (
        <div>
          <div class="flex items-center gap-2 px-3 mb-2 text-gray-400 dark:text-gray-500">
            <span class="shrink-0" set:html={CATEGORY_ICONS[cat.key]}></span>
            <h3 class="text-[11px] font-semibold uppercase tracking-[0.08em]">{cat.label}</h3>
          </div>
          <ul class="space-y-0.5">
            {tools.map((link) => {
              const linkPath = "/" + link.slug;
              const isActive = currentPath === linkPath;
              return (
                <li>
                  <a
                    href={linkPath}
                    class={`
                      relative flex items-center gap-3 px-3 py-2 rounded-[6px] text-sm font-medium
                      tracking-[-0.04em] transition-all duration-200
                      ${isActive
                        ? "bg-[#ebebeb] dark:bg-[#222222] text-black dark:text-white pl-[10px]"
                        : "text-gray-500 dark:text-gray-400 hover:bg-gray-100 dark:hover:bg-[#181818] hover:text-black dark:hover:text-white pl-3"
                      }
                    `}
                  >
                    {isActive && (
                      <span class="absolute left-0 top-1/2 -translate-y-1/2 w-0.5 h-5 bg-black dark:bg-white rounded-full" />
                    )}
                    {link.shortTitle}
                  </a>
                </li>
              );
            })}
          </ul>
        </div>
      );
    })}
  </div>
</nav>
